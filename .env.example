# Email Configuration (SMTP/IMAP)
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
POLL_INTERVAL=60

# WhatsApp Configuration (Whapi)
WHAPI_API_KEY=g5WCX39Az18DujFe46YltNxDZq8FfceT
WHAPI_PHONE_ID=your_whatsapp_phone_id_here
WHAPI_BASE_URL=https://gate.whapi.cloud

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/crm_fte_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=crm_fte_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INCOMING=tickets.incoming
KAFKA_TOPIC_RESPONSES=tickets.responses
KAFKA_TOPIC_ESCALATIONS=tickets.escalations

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Sentiment Analysis
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SENTIMENT_THRESHOLD=0.3

# Security
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
